// This is the OSS-Fuzz harness for google/go-cmp (OSS-Fuzz project "go-cmp",
// target FuzzDiff). It is a NATIVE Go fuzz harness:
//   func FuzzDiff(f *testing.F)   -> built with go-118-fuzz-build
//     (OSS-Fuzz `compile_native_go_fuzzer ... FuzzDiff`).
//
// It lives in package cmp (the harnessed package). go-118-fuzz-build replaces
// the stdlib `testing` import with the AdamKorcz fuzzing shim at build time, so
// this file is only compiled into the fuzz binary and does not change the
// project's normal `go test ./...` suite (cmp.Diff itself is exercised by the
// fuzz call here, comparing two arbitrary []byte values).

package cmp

import (
	"testing"
)

func FuzzDiff(f *testing.F) {
	f.Fuzz(func(t *testing.T, data1, data2 []byte) {
		_ = Diff(data1, data2)
	})
}
